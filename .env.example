# ---- Database (Neon Postgres) ----
# Pooled connection (host contains `-pooler`) — used by the app at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
# Direct connection (no `-pooler`) — used by `prisma db push` / migrations.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"

# Secret for signing session JWTs. Generate one: openssl rand -base64 32
AUTH_SECRET="change-me"

# ---- Claude API (optional) ----
# Enables real AI generation. Without it, the app falls back to local mock content.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-8

# Public site config
NEXT_PUBLIC_SITE_URL=http://localhost:3000
