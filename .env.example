# ---- Database (Neon Postgres) ----
# Pooled connection (host contains `-pooler`) — used by the app at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
# Direct connection (no `-pooler`) — used by `prisma db push` / migrations.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"

# Secret for signing session JWTs. Generate one: openssl rand -base64 32
AUTH_SECRET="change-me"

# ---- Claude API (optional) ----
# Enables real AI generation. Without it, the app falls back to local mock content.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-8

# ---- Social login (all optional; buttons hidden if unset) ----
# Google OAuth — create at https://console.cloud.google.com (Credentials → OAuth client)
# Authorized redirect URI: https://YOUR-DOMAIN/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Telegram login — create a bot with @BotFather, then /setdomain to your site
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Public site config (used to build OAuth redirect URLs in production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
